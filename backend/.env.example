# AI Tutor Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: Do NOT commit .env to GitHub!

# Required: Your OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Optional: YouTube API Key (for video content)
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=YOUR_KEY_HERE

# Port (usually 5000 for local development)
# Render will override this with the PORT environment variable
PORT=5000
